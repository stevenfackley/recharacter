# Copy to .env next to docker-compose.yml on the host. Never commit real values.

# Supabase cloud project (Dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (Dashboard -> Settings -> API). BYPASSES RLS — server only,
# never shipped to the browser. Required for one feature: account deletion
# (Settings -> Your data). Without it, deletion fails closed and everything
# else keeps working.
SUPABASE_SERVICE_ROLE_KEY=

# Managed-tier AI (server only)
ANTHROPIC_API_KEY=

# AI cost guardrails (optional; defaults shown). Per-user AI requests per minute
# (all tasks, BYOK included) and managed-tier (non-BYOK) input+output tokens per
# user per UTC day. BYOK calls are exempt from the token cap.
# AI_RATE_LIMIT_PER_MINUTE=10
# AI_MANAGED_DAILY_TOKEN_CAP=2000000

# Production KEK for BYOK key encryption: openssl rand -base64 32
# Losing this makes stored BYOK keys undecryptable (users just re-enter them).
AI_KEY_ENCRYPTION_SECRET=

# Public origin (Stripe redirects when payments are wired)
APP_BASE_URL=https://recharacter.us

# Cloudflare Zero Trust -> Tunnels -> your tunnel -> token
TUNNEL_TOKEN=

# Stripe (leave unset at launch: upgrade page degrades gracefully; BYOK unlocks)
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID=
