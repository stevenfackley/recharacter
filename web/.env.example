NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Managed-tier Anthropic key (server only) — used when a user has no BYOK credential.
ANTHROPIC_API_KEY=
# Base64, 32 bytes — KEK for encrypting BYOK keys at rest (server only).
AI_KEY_ENCRYPTION_SECRET=
# .NET routing service (dotnet run --project src/ReCharacter.RoutingApi)
ROUTING_API_URL=
# Stripe (server only) — one-time case-unlock checkout. Leave unset in dev/test: the
# upgrade page shows a "payments not yet configured" notice and BYOK remains the
# working entitlement path; no live key is needed for any test.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
# Used to build Stripe success/cancel redirect URLs.
APP_BASE_URL=http://localhost:3000
